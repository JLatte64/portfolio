{
  "name": "portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clean": "rimraf build dist .react-router node_modules/.vite node_modules/.tmp",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "predev": "npm run clean && npm run typecheck",
    "dev": "react-router dev",
    "prebuild": "npm run clean",
    "build": "npm run typecheck && react-router build && node copy-fallback.js",
    "prepreview": "npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vidstack/react": "^1.12.12",
    "dompurify": "^3.4.11",
    "embla-carousel-react": "^8.6.0",
    "html-to-image": "^1.11.13",
    "isbot": "^5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-helmet-async": "^3.0.0",
    "react-router": "^8.2.0",
    "react-router-dom": "^7.18.1",
    "react-zoom-pan-pinch": "^4.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@react-router/dev": "^8.2.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9"
  }
}
