          "sectionMedia": [
            {
              "mediaType": "paragraph",
              "content": "This system uses the stencil buffer, multiple custom render targets, custom shaders and extensions to Unity's Scriptable Render Pipeline (SRP) to allow for 256 individually-lit sprite layers."
